# --- Required ---

# Postgres connection string (Railway Postgres or local)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Required for webhook (M4) ---

# From Slack app config -> Basic Information -> Signing Secret
SLACK_SIGNING_SECRET=

# Jay's Slack user ID (Slack profile -> ... -> Copy member ID)
SLACK_USER_ID_JAY=U01ABC123

# --- Required for poller (M3): currently deployed bots ---

SLACK_BOT_TOKEN_AUDRA=xoxb-...
SLACK_BOT_TOKEN_JULES=xoxb-...
SLACK_BOT_TOKEN_OLLIE=xoxb-...

# --- Optional: agents not yet deployed; fill in as they come online ---

SLACK_BOT_TOKEN_CASH=
SLACK_BOT_TOKEN_LEX=
SLACK_BOT_TOKEN_HARPER=
SLACK_BOT_TOKEN_ATLAS=
SLACK_BOT_TOKEN_DIGBY=
SLACK_BOT_TOKEN_ARGUS=
SLACK_BOT_TOKEN_DEX=

# --- Tunables (defaults shown) ---

POLL_INTERVAL_SECONDS=5
POLL_BATCH_SIZE=10
MAX_POST_RETRIES=4
LOG_LEVEL=INFO
